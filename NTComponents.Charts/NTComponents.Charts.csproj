<Project Sdk="Microsoft.NET.Sdk.Razor">

    <PropertyGroup>
        <TargetFrameworks>net9.0;net10.0</TargetFrameworks>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <PackageId>NTComponents.Charts</PackageId>
        <Title>NTComponents.Charts</Title>
        <Description>Charts package for NTComponents with interactive Blazor visualizations powered by SkiaSharp.</Description>
        <Authors>NT Technologies</Authors>
        <RepositoryUrl>https://github.com/NT-Technologies/NTComponents.Charts</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageTags>blazor;charts;visualization;skia;ntcomponents</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
        <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
    </PropertyGroup>
	
	<ItemGroup>
		<SupportedPlatform Include="browser" />
	</ItemGroup>

    <ItemGroup>
        <None Include="..\README.md" Pack="true" PackagePath="\" />
        <None Include="..\LICENSE.txt" Pack="true" PackagePath="\" />
    </ItemGroup>
	
    <ItemGroup>
		<PackageReference Include="AspNetCore.SassCompiler" Version="1.97.1" />
		<PackageReference Include="SkiaSharp.Views.Blazor" Version="3.119.2" />
    </ItemGroup>

	<ItemGroup Condition="Exists('..\..\..\NTComponents\NTComponents.csproj')">
		<ProjectReference Include="..\..\..\NTComponents\NTComponents.csproj" />
	</ItemGroup>

	<ItemGroup Condition="!Exists('..\..\..\NTComponents\NTComponents.csproj')">
		<PackageReference Include="NTComponents" Version="1.21.0" />
	</ItemGroup>
	
	<ItemGroup Condition="'$(TargetFramework)' == 'net9.0'">
		<PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly">
			<Version>9.0.13</Version>
		</PackageReference>
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
		<PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly">
			<Version>10.0.3</Version>
		</PackageReference>
	</ItemGroup>

</Project>
